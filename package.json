{
  "name": "clip-image-viewer",
  "version": "1.4.1",
  "description": "Windows media viewer with CLIP STUDIO PAINT, RAW, modern image and video format support",
  "main": "src/main.js",
  "author": "verylovefurry",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node test/image-loader.test.js && node test/window-state.test.js && node test/updater.test.js",
    "licenses": "node scripts/collect-licenses.js",
    "icon": "node scripts/make-icon.js",
    "build": "npm run build:release",
    "build:win": "npm run licenses && npm run icon && electron-builder --win nsis dir --x64",
    "build:release": "npm run build:win && npm run package:portable",
    "package:portable": "node scripts/package-portable.js"
  },
  "dependencies": {
    "@discourse/jxr": "^1.0.0",
    "@imagemagick/magick-wasm": "^0.0.40",
    "@webtoon/psd": "^0.4.0",
    "adm-zip": "^0.5.16",
    "ag-psd": "^30.1.1",
    "bpg-decoder": "^0.0.7",
    "electron-updater": "^6.6.2",
    "sharp": "^0.34.3",
    "sql.js": "^1.13.0"
  },
  "optionalDependencies": {
    "@julianberger/libraw.js": "^3.3.1",
    "lightdrift-libraw": "^1.0.0-alpha.6"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.clipimageviewer.app",
    "productName": "Clip Image Viewer",
    "executableName": "ClipImageViewer",
    "directories": {
      "output": "../../outputs",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json",
      "README.md",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md"
    ],
    "extraFiles": [
      {
        "from": "licenses",
        "to": "licenses"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "verylovefurry",
      "repo": "Clip-Image-Viewer"
    },
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/sql.js/dist/*.wasm",
      "node_modules/lightdrift-libraw/build/Release/**/*",
      "node_modules/@julianberger/libraw.js/prebuilds/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "dir"],
      "artifactName": "Clip-Image-Viewer-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Clip Image Viewer",
      "include": "build/installer.nsh",
      "installerLanguages": [
        "ko_KR"
      ],
      "language": "1032",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
